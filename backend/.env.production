# Configuración de Servidor (Render/Producción)
PORT=3000
NODE_ENV=production

# Base de Datos (Variables que obtendrás de Supabase)
# Sustituye estas con los datos reales en el panel de control de Render/Railway
DB_HOST=tu_host_de_supabase.supabase.co
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=tu_password_seguro
DB_NAME=postgres

# Seguridad JWT (¡CAMBIA ESTO!)
JWT_SECRET=generar_una_clave_larga_y_aleatoria_para_produccion
JWT_EXPIRES_IN=24h
